rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Only allow specific fields to be changed
    function onlyUpdates(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // --- Users ---
    match /users/{userId} {
      // Anyone can read user profiles (public info only — emails are stored
      // but display name, photo, stats are the public-facing data)
      allow read: if true;

      // Users can create their own profile on signup
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['displayName', 'email'])
        && request.resource.data.displayName is string
        && request.resource.data.email is string;

      // Users can update ONLY their own profile, and only safe fields
      allow update: if isOwner(userId)
        && onlyUpdates(['displayName', 'photoURL', 'handle', 'reviewCount',
                         'followerCount', 'followingCount', 'followers', 'following',
                         'badges', 'tier']);

      // No deleting user profiles
      allow delete: if false;
    }

    // --- Places (taco spots) ---
    match /places/{placeId} {
      // Anyone can read places
      allow read: if true;

      // Signed-in users can add places (require name + address)
      allow create: if isSignedIn()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.address is string;

      // Signed-in users can update aggregate fields only
      // (review counts, averages, tags, wait counts, and external link fields)
      allow update: if isSignedIn()
        && onlyUpdates(['reviewCount', 'avgOverall', 'avgTortilla', 'avgProtein',
                         'avgSalsa', 'avgValue', 'waitYesCount', 'topTags',
                         'imageURL', 'websiteURL', 'yelpURL', 'googleMapsURL',
                         'orderURL', 'phone', 'photoURL', 'googleRating',
                         'googleReviewCount', 'googlePhotoURL']);

      // No deleting places
      allow delete: if false;
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;

      // Signed-in users can create reviews with their own userId
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.placeId is string
        && request.resource.data.overall is number
        && request.resource.data.overall >= 1
        && request.resource.data.overall <= 10;

      // Author can update their own review text/ratings.
      // Any signed-in user can update likes/commentCount (social interactions).
      allow update: if isSignedIn()
        && (
          // Author can update anything on their review
          resource.data.userId == request.auth.uid
          ||
          // Non-authors can only update like/comment counts
          onlyUpdates(['likes', 'commentCount', 'likedBy'])
        );

      // Only the review author can delete their own review
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // --- Comments (subcollection of reviews) ---
      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow delete: if isSignedIn()
          && resource.data.userId == request.auth.uid;

        allow update: if false;
      }
    }

    // --- Follows ---
    match /follows/{followId} {
      allow read: if true;

      // Only the follower can create a follow relationship
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid;

      // Only the follower can unfollow
      allow delete: if isSignedIn()
        && resource.data.followerId == request.auth.uid;

      allow update: if false;
    }

    // --- Stories (Beto's Table articles) ---
    match /stories/{storyId} {
      // Public can read published stories only
      allow read: if resource.data.status == 'published';

      // Admin (Ivan) has full access
      allow read, write: if isSignedIn()
        && request.auth.uid == 'zy8WSqtL3GUuyw89u1X1ZzENULP2';
    }

    // --- Newsletter Subscribers ---
    match /newsletter_subscribers/{subId} {
      // Anyone can subscribe (create)
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 0;

      // Admin (Ivan) has full access
      allow read, write: if isSignedIn()
        && request.auth.uid == 'zy8WSqtL3GUuyw89u1X1ZzENULP2';
    }

    // --- Outreach Pipeline (admin only) ---
    match /outreach/{outreachId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == 'zy8WSqtL3GUuyw89u1X1ZzENULP2';
    }

    // --- Catch-all: deny everything else ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
